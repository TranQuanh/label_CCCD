    "# ── Thống kê output files ─────────────────────────────────────────────────────\n",
    "import json\n",
    "from pathlib import Path\n",
    "\n",
    "print('📊 KẾT QUẢ LABEL')\n",
    "print('='*60)\n",
    "\n",
    "for split in ['train', 'test', 'valid']:\n",
    "    out_path = RESULT_DIR / f'{split}_labels.jsonl'\n",
    "    if not out_path.exists():\n",
    "        print(f'  {split:8s}: chưa có file')\n",
    "        continue\n",
    "\n",
    "    records = []\n",
    "    with open(out_path, encoding='utf-8') as f:\n",
    "        for line in f:\n",
    "            line = line.strip()\n",
    "            if line:\n",
    "                try: records.append(json.loads(line))\n",
    "                except: pass\n",
    "\n",
    "    parse_ok   = sum(1 for r in records if r.get('_meta', {}).get('parse_ok', True))\n",
    "    parse_fail = len(records) - parse_ok\n",
    "    size_mb    = out_path.stat().st_size / 1e6\n",
    "\n",
    "    print(f'\\n  📄 {split}_labels.jsonl ({size_mb:.1f} MB)')\n",
    "    print(f'     Tổng records : {len(records)}')\n",
    "    print(f'     JSON ok      : {parse_ok}')\n",
    "    print(f'     Parse fail   : {parse_fail}', '← cần review' if parse_fail else '')\n",
    "\n",
    "    # Kiểm tra checkpoint còn sót không\n",
    "    ckpt = RESULT_DIR / f'.checkpoint_{split}.json'\n",
    "    if ckpt.exists():\n",
    "        with open(ckpt) as f:\n",
    "            done_count = len(json.load(f).get('done', []))\n",
    "        print(f'     Checkpoint   : ⚠️  còn active ({done_count} ảnh) — chưa hoàn thành')\n",
    "    else:\n",
    "        print(f'     Checkpoint   : ✅ đã xóa (hoàn tất)')\n",
    "\n",
    "print('\\n' + '='*60)"
   ]
