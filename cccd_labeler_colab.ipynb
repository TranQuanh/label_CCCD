  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Ghi label_cccd.py vào Drive ──────────────────────────────────────────────\n",
    "code = '''\n",
    "import os, json, logging\n",
    "from pathlib import Path\n",
    "from typing import Optional\n",
    "from PIL import Image\n",
    "import torch\n",
    "from tqdm.auto import tqdm\n",
    "\n",
    "IMAGE_EXTENSIONS = {\".jpg\", \".jpeg\", \".png\", \".bmp\", \".webp\", \".tiff\"}\n",
    "\n",
    "SYSTEM_PROMPT = (\n",
    "    \"Bạn là hệ thống OCR chuyên đọc Căn cước công dân (CCCD) Việt Nam. \"\n",
    "    \"Chỉ trả về JSON thuần túy, không thêm bất kỳ text hay markdown nào khác.\"\n",
    ")\n",
    "\n",
    "USER_PROMPT = (\n",
    "    \"Đọc ảnh CCCD và trích xuất thông tin ra JSON với các trường sau. \"\n",
    "    \"Nếu không đọc được hoặc mặt thẻ không có trường nào thì để null:\\\\n\"\n",
    "    \"{\\\\n\"\n",
    "    \\'  \"so_cccd\": \"12 chữ số\",\\\\n\\'\n",
    "    \\'  \"ho_va_ten\": \"họ tên viết hoa\",\\\\n\\'\n",
    "    \\'  \"ngay_sinh\": \"DD/MM/YYYY\",\\\\n\\'\n",
    "    \\'  \"gioi_tinh\": \"Nam hoặc Nữ\",\\\\n\\'\n",
    "    \\'  \"quoc_tich\": \"Việt Nam\",\\\\n\\'\n",
    "    \\'  \"que_quan\": \"địa chỉ quê quán\",\\\\n\\'\n",
    "    \\'  \"noi_thuong_tru\": \"địa chỉ thường trú đầy đủ\",\\\\n\\'\n",
    "    \\'  \"ngay_het_han\": \"DD/MM/YYYY hoặc null\",\\\\n\\'\n",
    "    \\'  \"dac_diem_nhan_dang\": \"nếu có hoặc null\",\\\\n\\'\n",
    "    \\'  \"ngay_cap\": \"DD/MM/YYYY hoặc null\",\\\\n\\'\n",
    "    \\'  \"noi_cap\": \"nơi cấp thẻ hoặc null\",\\\\n\\'\n",
    "    \\'  \"mat_the\": \"truoc hoặc sau\"\\\\n\\'\n",
    "    \"}\"\n",
    ")\n",
    "\n",
    "HUMAN_VALUE = f\"<image>\\\\n{USER_PROMPT}\"\n",
    "\n",
    "\n",
    "def checkpoint_path(result_dir, split_name):\n",
    "    return Path(result_dir) / f\".checkpoint_{split_name}.json\"\n",
    "\n",
    "def load_checkpoint(ckpt_path):\n",
    "    ckpt_path = Path(ckpt_path)\n",
    "    if not ckpt_path.exists():\n",
    "        return set()\n",
    "    try:\n",
    "        with open(ckpt_path, \"r\", encoding=\"utf-8\") as f:\n",
    "            data = json.load(f)\n",
    "        done = set(data.get(\"done\", []))\n",
    "        print(f\"  [checkpoint] Resume: {len(done)} ảnh đã xong từ lần trước\")\n",
    "        return done\n",
    "    except Exception as e:\n",
    "        print(f\"  [checkpoint] Lỗi đọc ({e}), bắt đầu lại\")\n",
    "        return set()\n",
    "\n",
    "def save_checkpoint(ckpt_path, done_names):\n",
    "    try:\n",
    "        with open(ckpt_path, \"w\", encoding=\"utf-8\") as f:\n",
    "            json.dump({\"done\": sorted(done_names)}, f, ensure_ascii=False)\n",
    "    except Exception as e:\n",
    "        print(f\"  [checkpoint] Ghi lỗi: {e}\")\n",
    "\n",
    "def clear_checkpoint(ckpt_path):\n",
    "    ckpt_path = Path(ckpt_path)\n",
    "    if ckpt_path.exists():\n",
    "        ckpt_path.unlink()\n",
    "\n",
    "\n",
    "def load_model(model_name=\"Qwen/Qwen2.5-VL-7B-Instruct\", load_in_4bit=False):\n",
    "    print(f\"Loading model: {model_name}\")\n",
    "    import torch\n",
    "\n",
    "    kwargs = {\"trust_remote_code\": True, \"device_map\": \"auto\"}\n",
    "    if load_in_4bit:\n",
    "        from transformers import BitsAndBytesConfig\n",
    "        kwargs[\"quantization_config\"] = BitsAndBytesConfig(load_in_4bit=True)\n",
    "        print(\"  → 4-bit quantization bật\")\n",
    "    else:\n",
    "        kwargs[\"torch_dtype\"] = torch.bfloat16 if torch.cuda.is_available() else torch.float32\n",
    "\n",
    "    if \"Qwen3\" in model_name or \"qwen3\" in model_name.lower():\n",
    "        try:\n",
    "            from transformers import Qwen3VLForConditionalGeneration, AutoProcessor\n",
    "            processor = AutoProcessor.from_pretrained(model_name, trust_remote_code=True)\n",
    "            model = Qwen3VLForConditionalGeneration.from_pretrained(model_name, **kwargs)\n",
    "            model.eval()\n",
    "            print(f\"✅ Qwen3-VL loaded\")\n",
    "            return model, processor\n",
    "        except (ImportError, AttributeError):\n",
    "            print(\"⚠️  Qwen3VL không khả dụng → fallback Qwen2.5-VL-7B\")\n",
    "            model_name = \"Qwen/Qwen2.5-VL-7B-Instruct\"\n",
    "\n",
    "    from transformers import Qwen2_5_VLForConditionalGeneration, AutoProcessor\n",
    "    processor = AutoProcessor.from_pretrained(model_name, trust_remote_code=True)\n",
    "    model = Qwen2_5_VLForConditionalGeneration.from_pretrained(model_name, **kwargs)\n",
    "    model.eval()\n",
    "    print(f\"✅ Qwen2.5-VL loaded\")\n",
    "    return model, processor\n",
    "\n",
    "\n",
    "def infer_image(image_path, model, processor, max_new_tokens=512):\n",
    "    image = Image.open(image_path).convert(\"RGB\")\n",
    "    messages = [\n",
    "        {\"role\": \"system\", \"content\": [{\"type\": \"text\", \"text\": SYSTEM_PROMPT}]},\n",
    "        {\"role\": \"user\", \"content\": [{\"type\": \"image\", \"image\": image}, {\"type\": \"text\", \"text\": USER_PROMPT}]},\n",
    "    ]\n",
    "    text_input = processor.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)\n",
    "    inputs = processor(text=[text_input], images=[image], return_tensors=\"pt\", padding=True)\n",
    "    inputs = {k: v.to(model.device) for k, v in inputs.items()}\n",
    "    with torch.no_grad():\n",
    "        output_ids = model.generate(**inputs, max_new_tokens=max_new_tokens,\n",
    "                                    do_sample=False, temperature=None, top_p=None)\n",
    "    generated = output_ids[:, inputs[\"input_ids\"].shape[1]:]\n",
    "    return processor.batch_decode(generated, skip_special_tokens=True)[0].strip()\n",
    "\n",
    "\n",
    "def parse_json_safe(text):\n",
    "    import re\n",
    "    text = text.strip()\n",
    "    if text.startswith(\"```\"):\n",
    "        lines = text.split(\"\\\\n\")\n",
    "        end = len(lines) - 1 if lines[-1].strip() == \"```\" else len(lines)\n",
    "        text = \"\\\\n\".join(lines[1:end]).strip()\n",
    "    try:\n",
    "        return json.loads(text)\n",
    "    except json.JSONDecodeError:\n",
    "        m = re.search(r\"\\\\{.*?\\\\}\", text, re.DOTALL)\n",
    "        if m:\n",
    "            try:\n",
    "                return json.loads(m.group())\n",
    "            except Exception:\n",
    "                pass\n",
    "    return None\n",
    "\n",
    "\n",
    "def build_record(image_path, gpt_answer):\n",
    "    return {\n",
    "        \"image\": str(image_path),\n",
    "        \"conversations\": [\n",
    "            {\"from\": \"human\", \"value\": HUMAN_VALUE},\n",
    "            {\"from\": \"gpt\",   \"value\": gpt_answer},\n",
    "        ],\n",
    "    }\n",
    "\n",
    "\n",
    "def label_folder(input_dir, result_dir, output_filename, model, processor,\n",
    "                 max_new_tokens=512, reset=False, progress_callback=None):\n",
    "    input_dir  = Path(input_dir)\n",
    "    result_dir = Path(result_dir)\n",
    "    split_name = input_dir.name\n",
    "    ckpt_path  = checkpoint_path(result_dir, split_name)\n",
    "    output_path = result_dir / output_filename\n",
    "    result_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "    if reset:\n",
    "        for p in [ckpt_path, output_path]:\n",
    "            if Path(p).exists(): Path(p).unlink()\n",
    "        print(f\"[{split_name}] Reset xong\")\n",
    "\n",
    "    done_names  = load_checkpoint(ckpt_path)\n",
    "    all_images  = sorted([p for p in input_dir.iterdir() if p.suffix.lower() in IMAGE_EXTENSIONS])\n",
    "    todo        = [p for p in all_images if p.name not in done_names]\n",
    "\n",
    "    print(f\"[{split_name}] Tổng: {len(all_images)} | Đã xong: {len(done_names)} | Cần label: {len(todo)}\")\n",
    "    if not todo:\n",
    "        print(f\"[{split_name}] ✅ Tất cả đã hoàn thành!\")\n",
    "        return 0, 0, 0\n",
    "\n",
    "    write_mode = \"a\" if output_path.exists() else \"w\"\n",
    "    success = errors = parse_fail = 0\n",
    "\n",
    "    with open(output_path, write_mode, encoding=\"utf-8\") as f_out:\n",
    "        for i, img_path in enumerate(tqdm(todo, desc=f\"  {split_name}\", unit=\"img\")):\n",
    "            try:\n",
    "                raw    = infer_image(str(img_path), model, processor, max_new_tokens)\n",
    "                parsed = parse_json_safe(raw)\n",
    "                if parsed is not None:\n",
    "                    gpt_answer = json.dumps(parsed, ensure_ascii=False)\n",
    "                    success += 1\n",
    "                else:\n",
    "                    gpt_answer = raw\n",
    "                    parse_fail += 1\n",
    "\n",
    "                record = build_record(str(img_path), gpt_answer)\n",
    "                record[\"_meta\"] = {\"parse_ok\": parsed is not None, \"raw_output\": raw}\n",
    "                f_out.write(json.dumps(record, ensure_ascii=False) + \"\\\\n\")\n",
    "                f_out.flush()\n",
    "\n",
    "                done_names.add(img_path.name)\n",
    "                save_checkpoint(ckpt_path, done_names)\n",
    "\n",
    "                if progress_callback:\n",
    "                    progress_callback(i + 1, len(todo), split_name)\n",
    "\n",
    "            except Exception as e:\n",
    "                print(f\"  ERROR {img_path.name}: {e}\")\n",
    "                errors += 1\n",
    "                done_names.add(img_path.name)\n",
    "                save_checkpoint(ckpt_path, done_names)\n",
    "\n",
    "    if len(done_names) >= len(all_images):\n",
    "        clear_checkpoint(ckpt_path)\n",
    "        print(f\"[{split_name}] ✅ Hoàn tất — checkpoint đã xóa\")\n",
    "\n",
    "    print(f\"[{split_name}] ✅ {success} | parse_fail: {parse_fail} | error: {errors}\")\n",
    "    return success, parse_fail, errors\n",
    "'''\n",
    "\n",
    "code_path = CODE_DIR / 'label_cccd.py'\n",
    "code_path.write_text(code, encoding='utf-8')\n",
    "print(f'✅ Đã ghi code → {code_path}')\n",
    "\n",
    "# Thêm CODE_DIR vào sys.path để import\n",
    "import sys\n",
    "if str(CODE_DIR) not in sys.path:\n",
    "    sys.path.insert(0, str(CODE_DIR))\n",
    "print(f'✅ sys.path cập nhật')"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## Bước 4 — Load model\n",
    "\n",
    "> ⏱️ Lần đầu: download ~15GB, mất 5-10 phút tùy tốc độ mạng.  \n",
    "> Lần sau (model đã cache trong `/root/.cache`): load trong ~1 phút."
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Load model ────────────────────────────────────────────────────────────────\n",
    "import torch\n",
    "from label_cccd import load_model\n",
    "\n",
    "# Tự động bật 4-bit nếu VRAM < 14GB\n",
    "vram_gb = torch.cuda.get_device_properties(0).total_memory / 1e9 if torch.cuda.is_available() else 0\n",
    "use_4bit = vram_gb < 14\n",
    "\n",
    "if use_4bit:\n",
    "    print(f'⚠️  VRAM {vram_gb:.1f}GB < 14GB → bật 4-bit quantization')\n",
    "    !pip install -q bitsandbytes\n",
    "else:\n",
    "    print(f'✅ VRAM {vram_gb:.1f}GB — dùng bfloat16')\n",
    "\n",
    "model, processor = load_model(MODEL_NAME, load_in_4bit=use_4bit)\n",
    "\n",
    "# Hiển thị VRAM đang dùng sau khi load\n",
    "if torch.cuda.is_available():\n",
    "    used = torch.cuda.memory_allocated() / 1e9\n",
    "    total = torch.cuda.get_device_properties(0).total_memory / 1e9\n",
    "    print(f'📊 VRAM sau load: {used:.1f}/{total:.1f} GB')"
   ]
  },

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## Bước 5 — Chạy label\n",
    "\n",
    "> Checkpoint lưu sau **mỗi ảnh**. Nếu Colab disconnect, chạy lại từ **Bước 4** rồi **Bước 5** — không mất tiến độ."
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Chạy label tất cả splits ──────────────────────────────────────────────────\n",
    "import time\n",
    "from label_cccd import label_folder\n",
    "\n",
    "splits_to_run = ['train', 'test', 'valid'] if SPLITS == 'all' else (\n",
    "    [SPLITS] if isinstance(SPLITS, str) else SPLITS\n",
    ")\n",
    "\n",
    "# Lọc splits thực sự có ảnh\n",
    "IMAGE_EXTS = {'.jpg', '.jpeg', '.png', '.bmp', '.webp', '.tiff'}\n",
    "valid_splits = []\n",
    "for s in splits_to_run:\n",
    "    folder = DATA_DIR / s\n",
    "    if not folder.exists():\n",
    "        print(f'⚠️  Bỏ qua {s}: folder không tồn tại')\n",
    "        continue\n",
    "    imgs = [p for p in folder.iterdir() if p.suffix.lower() in IMAGE_EXTS]\n",
    "    if not imgs:\n",
    "        print(f'⚠️  Bỏ qua {s}: không có ảnh')\n",
    "        continue\n",
    "    valid_splits.append(s)\n",
